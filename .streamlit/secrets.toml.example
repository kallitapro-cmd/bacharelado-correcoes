# Exemplo de configuração de secrets para o Corretor Acadêmico.
#
# COMO USAR (desenvolvimento local):
#   1. Copie este arquivo para .streamlit/secrets.toml
#        cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#   2. Preencha cada chave com o valor real (ver descrição abaixo).
#   3. NUNCA commite secrets.toml — o .gitignore já bloqueia o arquivo.
#
# COMO USAR (Streamlit Cloud):
#   No painel da app, acesse Settings > Secrets e cole o conteúdo deste
#   arquivo com os valores reais. O Streamlit injeta os valores em
#   st.secrets em runtime.
#
# Consulte docs/guides/deploy.md para o passo a passo completo do deploy.

# --- Obrigatório ------------------------------------------------------------

# Chave da API Anthropic (obrigatória).
# Obtenha em https://console.anthropic.com/settings/keys
# Sem essa chave, a app exibe mensagem de erro no startup e não inicia.
ANTHROPIC_API_KEY = "sk-ant-..."

# Chave de cookie do streamlit-authenticator (obrigatória).
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
# Deve ter pelo menos 32 caracteres aleatórios.
AUTH_COOKIE_KEY = "string-aleatoria-32-chars"

# --- Opcional ---------------------------------------------------------------

# Hard limit de custo por sessão em reais (R$). Consulte ADR-005.
# Padrão: 15.0 (cobre folgadamente uma turma de 120 alunos).
# Aumente para turmas grandes ou batches com muitas regenerações.
# Exemplo: MAX_COST_BRL = "40.0" para 300 alunos.
MAX_COST_BRL = "15.0"
